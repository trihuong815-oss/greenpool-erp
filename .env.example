# ============================================
# GREEN POOL ERP — Environment Variables
# ============================================
# 1. Copy file này thành .env.local
# 2. Lấy 2 giá trị từ Supabase Dashboard → Settings → API
# 3. Paste vào dưới đây

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY_HERE

# Optional: Service role key (chỉ dùng cho seed data, KHÔNG commit lên Git)
# SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY
