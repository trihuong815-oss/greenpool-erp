rules_version = '2';

// ============================================================
// Firestore Security Rules — Green Pool ERP Checklist
// Phản chiếu RLS Supabase: admin all, QLCS facility, TP dept,
// shared_shift cs+bp+ca, assigned_to self.
//
// Nguyên tắc:
// - profiles: read self-or-admin, write admin-only (Issue 1).
// - templates: tách create/update để dùng đúng resource vs request.resource.
// - instances + sub: scope check qua matchesUserScope().
// - audit log: append-only, scope check khi create.
// - catch-all deny ở cuối.
// ============================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // ---- Helpers ----
    // Phase A.3 (2026-06-07) CRITICAL fix: profile collection đã đổi từ `profiles/{uid}` → `users/{uid}`
    // ở Phase 4 migration Supabase→Firebase. Rules vẫn check `profiles/` → returns null → mọi helper
    // role/facility/dept TRỞ THÀNH null → defense-in-depth GONE (Admin SDK bypass nên không ai thấy).
    // Field rename Phase 1.5 dual-write drop: role_code→roleId, facility_id→branchId,
    // department_id→departmentId. shift_assignment→shiftAssignment.
    function isSignedIn() {
      return request.auth != null;
    }
    function userProfile() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    function userRole() {
      return userProfile().roleId;
    }
    function isAdmin() {
      return isSignedIn() && userRole() in ['CEO','ADMIN','GD_KD','GD_VP'];
    }
    function isQLCS() {
      return isSignedIn() && userRole().matches('QLCS_.*');
    }
    function isTP() {
      return isSignedIn() && (userRole().matches('TP_.*') || userRole() == 'TIBAN_TT');
    }
    function userFacility() {
      return userProfile().branchId;
    }
    function userDepartment() {
      return userProfile().departmentId;
    }
    function userShift() {
      return userProfile().shiftAssignment;
    }
    function isSharedShift() {
      return userProfile().isSharedShiftAccount == true;
    }
    function matchesUserScope(instanceData) {
      return
        isAdmin()
        || (isQLCS() && instanceData.facility_id == userFacility())
        || (isTP()   && instanceData.department_id == userDepartment())
        || instanceData.assigned_to == request.auth.uid
        || (isSharedShift()
            && instanceData.facility_id    == userFacility()
            && instanceData.department_id  == userDepartment()
            && instanceData.shift_type     == userShift());
    }
    function isTerminalStatus(s) {
      return s == 'submitted' || s == 'approved' || s == 'failed';
    }
    function instanceDoc(iid) {
      return get(/databases/$(database)/documents/checklists/$(iid)).data;
    }
    function templateDoc(tid) {
      return get(/databases/$(database)/documents/templates/$(tid)).data;
    }

    // ---- Templates ----
    match /templates/{templateId} {
      allow read: if isSignedIn();

      // CREATE: dùng request.resource.data (chưa có resource)
      allow create: if isAdmin()
        || (isQLCS() && request.resource.data.block_id == 'KD')
        || (isTP()   && request.resource.data.department_id == userDepartment());

      // UPDATE: dùng resource.data (doc cũ) để check quyền theo state hiện tại.
      // Đồng thời chặn không cho đổi block_id sang ngoài scope của user.
      allow update: if isAdmin()
        || (isQLCS()
            && resource.data.block_id == 'KD'
            && request.resource.data.block_id == 'KD')
        || (isTP()
            && resource.data.department_id == userDepartment()
            && request.resource.data.department_id == userDepartment());

      allow delete: if isAdmin();

      match /items/{itemId} {
        allow read: if isSignedIn();
        // CREATE/UPDATE: phải parent template tồn tại và user có scope.
        allow create, update: if isAdmin()
          || (isQLCS() && templateDoc(templateId).block_id == 'KD')
          || (isTP()   && templateDoc(templateId).department_id == userDepartment());
        allow delete: if isAdmin();
      }
    }

    // ---- Instances ----
    match /checklists/{instanceId} {
      allow read: if matchesUserScope(resource.data);

      allow create: if isAdmin()
        || (isQLCS() && request.resource.data.facility_id == userFacility());

      // UPDATE: scope + instance chưa terminal. Chặn đổi facility ra khỏi scope.
      allow update: if matchesUserScope(resource.data)
        && !isTerminalStatus(resource.data.status)
        && (isAdmin() || request.resource.data.facility_id == resource.data.facility_id);

      allow delete: if isAdmin();

      match /items/{itemId} {
        // Đọc: scope của parent instance
        allow read: if matchesUserScope(instanceDoc(instanceId));

        // Tạo item (auto-seed): scope của parent instance, parent chưa terminal
        allow create: if matchesUserScope(instanceDoc(instanceId))
          && !isTerminalStatus(instanceDoc(instanceId).status);

        // Tick/uncheck: scope + parent chưa terminal
        allow update: if matchesUserScope(instanceDoc(instanceId))
          && !isTerminalStatus(instanceDoc(instanceId).status);

        allow delete: if isAdmin();
      }

      match /evidenceFiles/{evidenceId} {
        allow read: if matchesUserScope(instanceDoc(instanceId));

        // Tạo metadata file: scope + uploaded_by là chính user
        allow create: if matchesUserScope(instanceDoc(instanceId))
          && request.resource.data.uploaded_by == request.auth.uid;

        // User không được sửa/xoá metadata — Cloud Function dọn 7 ngày (admin)
        allow update, delete: if isAdmin();
      }
    }

    // ---- Audit logs (chuẩn Phase 1.5): append-only, mọi module ----
    // Schema: { action, module, userId, branchId, before, after, createdAt,
    //           actor_name, actor_role, instanceId?, templateId?, details? }
    // (Admin SDK ở server bypass rules; rules này áp dụng nếu client SDK ghi
    //  trực tiếp — hiện UI luôn ghi qua API routes, nên rule này chủ yếu là
    //  defense-in-depth.)
    match /auditLogs/{logId} {
      // Phase C.4 (2026-06-07): WORM (write-once read-many) contract.
      // - Log entry là bằng chứng compliance; cấm sửa/xoá sau khi ghi.
      // - Create chỉ chấp nhận shape hợp lệ → chặn tampering ghi rác/fake.
      // - Update/delete = false TUYỆT ĐỐI (cả client lẫn admin SDK nên tránh).

      // Đọc: admin xem mọi log; user xem log thuộc instance có scope.
      allow read: if isAdmin()
        || (resource.data.instanceId is string
            && matchesUserScope(instanceDoc(resource.data.instanceId)));

      // Insert: validate shape + actor = current uid + scope check.
      // Required fields: action (str), module (str trong allow-list), userId, createdAt.
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        // Shape validation — defense-in-depth chống ghi log méo
        && request.resource.data.action is string
        && request.resource.data.action.size() > 0
        && request.resource.data.action.size() <= 100
        && request.resource.data.module is string
        && request.resource.data.module in ['checklist','sales','users','templates','dashboard','giaoviec','ky-thuat']
        && request.resource.data.createdAt is timestamp
        && (
          request.resource.data.module != 'checklist'
          || (request.resource.data.instanceId is string
              && matchesUserScope(instanceDoc(request.resource.data.instanceId)))
        );

      // WORM: tuyệt đối KHÔNG cho update/delete — kể cả admin client.
      // Admin SDK (server-side) bypass rules nhưng codebase guard via grep CI.
      allow update, delete: if false;
    }

    // ---- Reference collections ----
    match /branches/{id}    { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /facilities/{id}  { allow read: if isSignedIn(); allow write: if isAdmin(); }  // legacy backup
    match /departments/{id} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /roles/{id}       { allow read: if isSignedIn(); allow write: if isAdmin(); }

    // ---- Leads (Phase 6): branch-scoped, schema Lead Pipeline ----
    match /leads/{leadId} {
      allow read: if isSignedIn() && (
        isAdmin() || isTP() || (userFacility() == resource.data.branchId)
      );
      allow create: if isSignedIn()
        && request.resource.data.createdBy == request.auth.uid
        && (isAdmin() || (userFacility() == request.resource.data.branchId));
      allow update: if isSignedIn()
        && resource.data.branchId == request.resource.data.branchId    // immutable
        && (isAdmin() || (userFacility() == resource.data.branchId));
      allow delete: if isAdmin();
    }

    // ---- Lead Activities (Phase 6): append-only ----
    match /leadActivities/{activityId} {
      allow read: if isSignedIn() && (
        isAdmin() || isTP() || (userFacility() == resource.data.branchId)
      );
      allow create: if isSignedIn()
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.saleId == request.auth.uid
        && (isAdmin() || (userFacility() == request.resource.data.branchId));
      allow update: if false;                                          // append-only
      allow delete: if isAdmin();
    }

    // ---- Package Groups (Phase 6.G): nhóm gói per branch ----
    // CRUD ĐẦU MỤC: CHỈ admin (CEO/GD_KD). QLCS read-only (để chọn dropdown nhập doanh số).
    match /packageGroups/{groupId} {
      allow read: if isSignedIn();
      allow create: if isAdmin() && request.resource.data.createdBy == request.auth.uid;
      allow update: if isAdmin()
        && resource.data.branchId == request.resource.data.branchId;  // immutable
      allow delete: if isAdmin();
    }

    // ---- Packages (Phase 6.G): gói cụ thể trong group ----
    // CRUD ĐẦU MỤC: CHỈ admin. QLCS read-only.
    match /packages/{packageId} {
      allow read: if isSignedIn();
      allow create: if isAdmin() && request.resource.data.createdBy == request.auth.uid;
      allow update: if isAdmin()
        && resource.data.branchId == request.resource.data.branchId   // immutable
        && resource.data.groupId == request.resource.data.groupId;    // immutable
      allow delete: if isAdmin();
    }

    // ---- Package Sales (Phase 6.H): entry doanh số per period × sale × package ----
    match /packageSales/{entryId} {
      allow read: if isSignedIn() && (
        isAdmin() || isTP() || (userFacility() == resource.data.branchId)
      );
      allow create: if isSignedIn()
        && request.resource.data.createdBy == request.auth.uid
        && (isAdmin() || (userFacility() == request.resource.data.branchId));
      allow update: if isSignedIn()
        && resource.data.branchId == request.resource.data.branchId
        && (isAdmin() || (userFacility() == resource.data.branchId));
      allow delete: if isAdmin();
    }

    // ---- Sales Targets (Phase 6.I): mục tiêu năm/tháng per branch ----
    // Đọc: signed-in. Ghi: CHỈ admin.
    match /salesTargets/{targetId} {
      allow read: if isSignedIn();
      allow create: if isAdmin() && request.resource.data.createdBy == request.auth.uid;
      allow update: if isAdmin()
        && resource.data.branchId == request.resource.data.branchId
        && resource.data.year == request.resource.data.year;
      allow delete: if isAdmin();
    }

    // ---- Sales Entries (Phase 6.E): bảng tổng nhập tay, doc ID deterministic ----
    // Schema: period, periodType, year, month, day?, branchId, saleId, saleName, source,
    //          leads, closed, notClosed, revenue, createdAt/By, updatedAt/By
    match /salesEntries/{entryId} {
      allow read: if isSignedIn() && (
        isAdmin() || isTP() || (userFacility() == resource.data.branchId)
      );
      // CREATE/UPDATE: branchId immutable; admin (any) hoặc người trong scope
      allow create: if isSignedIn()
        && request.resource.data.createdBy == request.auth.uid
        && (isAdmin() || (userFacility() == request.resource.data.branchId));
      allow update: if isSignedIn()
        && resource.data.branchId == request.resource.data.branchId
        && (isAdmin() || (userFacility() == resource.data.branchId));
      allow delete: if isAdmin();
    }

    // ---- Sales (Phase 6 schema mới): branch-scoped + leadId required + immutable ----
    // Schema: leadId, packageId, packageName, amount, closeSource, saleBy, branchId, status...
    match /sales/{saleId} {
      allow read: if isSignedIn() && (
        isAdmin() || isTP() || (userFacility() == resource.data.branchId)
      );
      allow create: if isSignedIn()
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.leadId is string
        && (isAdmin() || (userFacility() == request.resource.data.branchId));
      // branchId + leadId luôn immutable
      allow update: if isSignedIn()
        && resource.data.branchId == request.resource.data.branchId
        && resource.data.leadId == request.resource.data.leadId
        && (isAdmin() || (userFacility() == resource.data.branchId));
      allow delete: if isAdmin();
    }

    // ---- Users (Phase 4: rename profiles → users) ----
    // Phase A.3 (2026-06-07) CRITICAL: chính thức thêm rules cho `users/` collection.
    // Trước đây chỉ có rules cho `profiles/` (legacy collection, hiện đã empty).
    // Read: chính mình hoặc admin. Write: chỉ admin/CEO (qua Admin SDK qua API).
    match /users/{id} {
      allow read: if isSignedIn() && (isAdmin() || request.auth.uid == id);
      allow write: if false; // mọi mutation qua /api/admin/users (Admin SDK bypass + audit log)
    }

    // ---- Profiles (LEGACY - sẽ xóa Phase B) ----
    // Giữ rules để collection cũ (nếu còn doc) vẫn quản chặt; không có write cho phép.
    match /profiles/{id} {
      allow read: if isSignedIn() && (isAdmin() || request.auth.uid == id);
      allow write: if false;
    }

    // ---- Tasks (Phase 7): Đề xuất · Nhiệm vụ · Giao việc ----
    // Read: signed-in (server-side scope filter qua API GET).
    // Write: CHỈ qua API (Admin SDK bypass rules). Client-side write bị chặn.
    match /tasks/{taskId} {
      allow read: if isSignedIn();
      allow write: if false;

      // Subcollection comments — timeline + status change + approval events
      match /comments/{commentId} {
        allow read: if isSignedIn();
        allow write: if false;
      }
    }

    // ---- Notifications (V6.4 P2) ----
    // Read: chỉ chủ notification (userId === auth.uid) — client-side query có thể đọc.
    // Write: CHỈ qua API (Admin SDK bypass rules). Client KHÔNG mark read trực tiếp
    //        — phải gọi PATCH /api/notifications/[id] để có audit + permission check.
    match /notifications/{notiId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow write: if false;
    }

    // ---- Chat access logs (Phase 13.5 — Security audit) ----
    // Append-only audit log: ai đọc/gửi/react/upload tin nhắn vào conv nào.
    // CHỈ admin (CEO/GD) đọc được — KHÔNG ai khác kể cả người trong conv.
    // WRITE: server Admin SDK only (bypass rules).
    match /chatAccessLogs/{logId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // ---- Conversations + Messages (Phase 13 — Chat) ----
    // Schema: participantIds[] (sorted), participantNames{}, lastMessage,
    //         lastMessageAt, readBy{uid:ts}, typing{uid:ts}, channel?, type, ...
    // READ:  CHỈ participant (uid trong participantIds). Áp dụng cho cả 1-1, group, channel.
    // WRITE: CHỈ server (Admin SDK qua API routes /api/chat/*). Client-side write deny tuyệt đối.
    // Pattern: subcollection messages dùng get() để kiểm tra membership của parent conv.
    match /conversations/{cid} {
      allow read:  if isSignedIn()
        && request.auth.uid in resource.data.participantIds;
      allow write: if false;

      match /messages/{mid} {
        // Subcollection — phải get() parent conv để check participant.
        // 1 read parent per query (Firestore cache trong cùng request).
        allow read:  if isSignedIn()
          && request.auth.uid in get(/databases/$(database)/documents/conversations/$(cid)).data.participantIds;
        allow write: if false;
      }
    }

    // ---- Phase C.2 (2026-06-07): featureFlags ----
    // Admin UI có thể read/write; client app load qua RSC server-side.
    // Doc shape: { enabled, allowList?, allowRoles?, rolloutPercent? }.
    match /featureFlags/{flagKey} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // ---- Phase C.3 (2026-06-07): rateLimits ----
    // Chỉ Admin SDK (server-side) ghi vào collection này.
    // Client KHÔNG cần đọc trực tiếp — counter là internal.
    match /rateLimits/{key} {
      allow read, write: if false;
    }

    // ---- Phase PWA-Stability (2026-06-09): inAppNotifications ----
    // Per-user noti queue. Owner read/update (mark seenAt). Server-only create
    // (Admin SDK bypass rules). Delete deny — server cleanup tự.
    match /inAppNotifications/{uid}/items/{notiId} {
      allow read: if isSignedIn() && request.auth.uid == uid;
      allow update: if isSignedIn() && request.auth.uid == uid
        // Chỉ cho update field seenAt (mark seen) — KHÔNG cho sửa title/body
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['seenAt']);
      allow create: if false;   // Admin SDK only
      allow delete: if false;
    }

    // ---- Sales v2 (2026-06-17) — Doanh số v2 module ----
    // Workflow: Sale nhập daily batch → kế toán/TP_KE/QLCS xem → kế toán/top duyệt.
    // WRITE: 100% server-side (Admin SDK qua /api/sales-v2/*) — client write deny.
    // READ scope:
    //   - isAdmin() (CEO/ADMIN/GD_KD/GD_VP): all
    //   - TP_KE (HQ kế toán): all
    //   - Sale owner: only mình
    //   - NV_KE / QLCS: branch của mình

    // salesDailyBatches: meta theo Sale × ngày
    match /salesDailyBatches/{batchId} {
      allow read: if isSignedIn() && (
        isAdmin() ||
        userRole() == 'TP_KE' ||
        request.auth.uid == resource.data.saleId ||
        ((userRole() == 'NV_KE' || isQLCS()) &&
         resource.data.branchId == userFacility())
      );
      allow write: if false; // Admin SDK only
    }

    // salesTransactions: 1 doc / dòng grid
    match /salesTransactions/{txId} {
      allow read: if isSignedIn() && (
        isAdmin() ||
        userRole() == 'TP_KE' ||
        request.auth.uid == resource.data.saleId ||
        ((userRole() == 'NV_KE' || isQLCS()) &&
         resource.data.branchId == userFacility())
      );
      allow write: if false;
    }

    // salesAuditLogs: append-only, đọc giới hạn (audit trail).
    // Admin + TP_KE + chính actor đọc được. Sale không cần đọc audit của batch mình
    // (đã có UI hiển thị status/lý do trả lại trên batch doc).
    match /salesAuditLogs/{logId} {
      allow read: if isSignedIn() && (
        isAdmin() ||
        userRole() == 'TP_KE' ||
        request.auth.uid == resource.data.changedBy
      );
      allow write: if false;
    }

    // salesMonthlySummary: rebuild via cron daily — read theo cùng scope batch.
    match /salesMonthlySummary/{id} {
      allow read: if isSignedIn() && (
        isAdmin() ||
        userRole() == 'TP_KE' ||
        request.auth.uid == resource.data.saleId ||
        ((userRole() == 'NV_KE' || isQLCS()) &&
         resource.data.branchId == userFacility())
      );
      allow write: if false;
    }

    // ---- V7 Promo (2026-06-18) — Chương trình khuyến mãi ----
    // WRITE: 100% server-side qua /api/sales-v2/programs/* (Admin SDK) — client write deny.
    // READ scope:
    //   - Admin (CEO/ADMIN/CHU_TICH/GD_KD/GD_VP): all
    //   - TP_KE: all (tổng kế toán xem hết)
    //   - QLCS, NV_KE: programs của branch mình
    //   - Sale (NV_SALE, NV_SALE_PT): programs branch mình + status='active' (qua API /available)
    match /salesPrograms/{programId} {
      allow read: if isSignedIn() && (
        isAdmin() ||
        userRole() == 'CHU_TICH' ||
        userRole() == 'TP_KE' ||
        (resource.data.branchId == userFacility() && (
          isQLCS() ||
          userRole() == 'NV_KE' ||
          userRole() == 'NV_SALE' ||
          userRole() == 'NV_SALE_PT'
        ))
      );
      allow write: if false; // Admin SDK only
    }

    // ---- V8 Reception (2026-06-18) — Doanh thu quầy lễ tân ----
    // WRITE: 100% server-side qua /api/sales-v2/reception/* (Admin SDK).
    // READ:
    //   - Admin (CEO/ADMIN/CHU_TICH/GD_KD/GD_VP): all
    //   - TP_KE / TP_GS: all
    //   - QLCS / NV_KE: branch của mình
    match /salesReceptionBatches/{batchId} {
      allow read: if isSignedIn() && (
        isAdmin() ||
        userRole() == 'CHU_TICH' ||
        userRole() == 'TP_KE' ||
        userRole() == 'TP_GS' ||
        (resource.data.branchId == userFacility() && (
          isQLCS() ||
          userRole() == 'NV_KE'
        ))
      );
      allow write: if false;
    }
    match /salesReceptionPricing/{branchId} {
      allow read: if isSignedIn() && (
        isAdmin() ||
        userRole() == 'CHU_TICH' ||
        userRole() == 'TP_KE' ||
        userRole() == 'TP_GS' ||
        (branchId == userFacility() && (
          isQLCS() ||
          userRole() == 'NV_KE'
        ))
      );
      allow write: if false;
    }

    // ---- Catch-all deny ----
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
